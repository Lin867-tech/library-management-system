<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                      http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- 1. 字符编码过滤器（改用标准Servlet过滤器，无依赖问题）
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>javax.servlet.http.HttpFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>  -->

    <!-- 2. 仅保留项目中存在的Servlet映射 -->
    <!-- 通用登录 -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.library.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- 通用登出 -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.library.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- 读者注册 -->
    <servlet>
        <servlet-name>ReaderRegisterServlet</servlet-name>
        <servlet-class>com.library.controller.ReaderRegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReaderRegisterServlet</servlet-name>
        <url-pattern>/reader/register</url-pattern>
    </servlet-mapping>

    <!-- 图书列表 -->
    <servlet>
        <servlet-name>BookListServlet</servlet-name>
        <servlet-class>com.library.controller.BookListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookListServlet</servlet-name>
        <url-pattern>/book/list</url-pattern>
        <url-pattern>/reader/bookList</url-pattern>
    </servlet-mapping>

    <!-- 借阅/归还 -->
    <servlet>
        <servlet-name>BorrowServlet</servlet-name>
        <servlet-class>com.library.controller.BorrowServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BorrowServlet</servlet-name>
        <url-pattern>/borrow/borrow</url-pattern>
        <url-pattern>/reader/borrowList</url-pattern>
    </servlet-mapping>

    <!-- 预约管理 -->
    <servlet>
        <servlet-name>ReservationServlet</servlet-name>
        <servlet-class>com.library.controller.ReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationServlet</servlet-name>
        <url-pattern>/reserve/*</url-pattern>
        <!-- 让/reserve/list指向doGet方法 -->
        <url-pattern>/reserve/list</url-pattern>
    </servlet-mapping>


    <!-- 管理员添加图书 -->
    <servlet>
        <servlet-name>AdminAddBookServlet</servlet-name>
        <servlet-class>com.library.controller.AdminAddBookServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminAddBookServlet</servlet-name>
        <url-pattern>/admin/book/add</url-pattern>
    </servlet-mapping>

    <!-- 管理员管理读者 -->
    <servlet>
        <servlet-name>AdminReaderManageServlet</servlet-name>
        <servlet-class>com.library.controller.AdminReaderManageServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminReaderManageServlet</servlet-name>
        <url-pattern>/admin/reader/*</url-pattern>
        <url-pattern>/admin/reader/list</url-pattern>
    </servlet-mapping>

    <!-- 图书状态更新映射 -->
    <servlet>
        <servlet-name>AdminUpdateBookStatusServlet</servlet-name>
        <servlet-class>com.library.controller.AdminUpdateBookStatusServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUpdateBookStatusServlet</servlet-name>
        <url-pattern>/admin/book/updateStatus</url-pattern>
    </servlet-mapping>


    <!-- JSP 性能优化：关闭开发模式，禁止每次请求重新编译 -->
    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <trim-directive-whitespaces>true</trim-directive-whitespaces>
        </jsp-property-group>
    </jsp-config>


    <!-- 3. 欢迎页配置 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- 4. 会话超时配置 -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>


</web-app>